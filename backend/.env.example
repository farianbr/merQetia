# Server
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/merqetia

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# AI Summary (OpenAI-compatible)
AI_KEY=your_openai_api_key
AI_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
# Set to false to disable AI summary generation
AI_SUMMARY_ENABLED=true

# Employee Invite
INVITE_TOKEN_SECRET=your_invite_token_secret_change_in_production

# Email (Nodemailer) - fill in your SMTP details
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM="merQetia <no-reply@merqetia.com>"

# App URL (used in invite links)
APP_URL=http://localhost:5173

#Google OAuth Credentials
GOOGLE_CLIENT_ID=<from the console>
GOOGLE_CLIENT_SECRET=<from the console>
GOOGLE_REDIRECT_URI=http://localhost:5000/api/integrations/google/callback

# File storage — Cloudflare R2 (S3-compatible)
# REQUIRED — the server refuses to start without these (there is no local-disk
# fallback). Create the buckets + an API token with Object Read & Write on BOTH
# buckets in the Cloudflare dashboard.
R2_ACCOUNT_ID=<cloudflare account id>
R2_ACCESS_KEY_ID=<r2 api token access key id>
R2_SECRET_ACCESS_KEY=<r2 api token secret access key>
# Optional: override the S3 endpoint (defaults to https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com)
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# PRIVATE bucket — chat/order attachments (confidential). Keep public access OFF.
# Files are streamed only to authorized users; there is intentionally no public URL.
R2_BUCKET=merqetia-attachments

# PUBLIC bucket — avatars only (low-sensitivity profile photos). Enable public
# access and set the public base URL below (r2.dev domain or a custom domain, no
# trailing slash). Only avatars ever land here.
R2_PUBLIC_BUCKET=merqetia-avatars
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev

# PDF generation (Puppeteer / Chromium)
# Leave unset in production — Puppeteer uses the Chromium it downloads on install
# (cached in .cache/puppeteer via .puppeteerrc.cjs). Set only to point at a
# specific browser binary, e.g. a system Chrome locally.
# PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
